{
  "name": "@0xhoneyjar/inventory",
  "version": "0.1.0",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": ["dist", "fixtures"],
  "scripts": {
    "build": "tsc",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "typecheck:server": "tsc --noEmit -p tsconfig.server.json",
    "serve": "bun src/server/server.ts",
    "openapi:emit": "bun src/server/emit-openapi.ts"
  },
  "dependencies": {
    "ethereum-cryptography": "^2.2.1"
  },
  "devDependencies": {
    "vitest": "^1.6.0",
    "typescript": "^5.4.5",
    "@types/node": "^20.12.7"
  }
}
