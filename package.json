{
  "name": "@0xhoneyjar/inventory",
  "version": "0.1.0",
  "type": "module",
  "private": true,
  "description": "Sovereign read-side inventory aggregator — a Hyper (Bun) service consumed over HTTP + MCP",
  "scripts": {
    "prepare": "./scripts/prepare-effect.sh",
    "dev": "bun --hot src/app.ts",
    "start": "bun src/app.ts",
    "serve": "bun src/app.ts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "openapi:emit": "bun src/emit-openapi.ts",
    "mcp:emit": "bun src/emit-mcp.ts"
  },
  "dependencies": {
    "@freeside/collection-protocol": "file:vendor/collection-protocol/freeside-collection-protocol-1.0.0.tgz",
    "effect": "^3.21.0",
    "ethereum-cryptography": "^2.2.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "^1.3.14",
    "@types/node": "^20.12.7",
    "@usehyper/cli": "^0.1.1",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  }
}
